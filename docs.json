{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Trucklab Documentation",
  "colors": {
    "primary": "#D6A514",
    "light": "#F2C94C",
    "dark": "#9E7610"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "pages": [
          "index",
          "getting-started/overview",
          "getting-started/initial-setup",
          "getting-started/invite-your-team"
        ]
      },
      {
        "group": "Manage your workspace",
        "icon": "warehouse",
        "pages": [
          "guides/clients",
          "guides/drivers",
          "guides/trucks"
        ]
      },
      {
        "group": "Plan operations",
        "icon": "calendar-days",
        "pages": [
          "guides/planning/create-a-plan",
          "guides/planning/recurring-trips",
          "guides/planning/review-and-publish"
        ]
      },
      {
        "group": "Understand Trucklab",
        "icon": "book-open",
        "pages": [
          "concepts/roles-and-permissions",
          "concepts/planning-workflow",
          "glossary"
        ]
      },
      {
        "group": "Help",
        "icon": "life-ring",
        "pages": [
          "troubleshooting/common-issues"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation repository",
          "href": "https://github.com/Trucklab-io/documentation",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Docs feedback",
        "href": "https://github.com/Trucklab-io/documentation/issues/new"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Trucklab on GitHub",
      "href": "https://github.com/Trucklab-io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Trucklab-io"
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.trucklab.io"
    }
  }
}
